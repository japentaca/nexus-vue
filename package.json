{
  "name": "@japentaca/nexus-vue",
  "version": "1.0.1",
  "description": "Vue.js components for NexusUI audio interfaces",
  "main": "dist/nexus-vue.umd.js",
  "module": "dist/nexus-vue.es.js",
  "types": "index.d.ts",
  "files": [
    "dist",
    "index.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/nexus-vue.es.js",
      "require": "./dist/nexus-vue.umd.js"
    },
    "./style.css": "./dist/nexus-vue.css"
  },
  "keywords": ["vue", "nexusui", "audio", "components"],
  "author": "japentaca",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/japentaca/nexus-vue.git"
  },
  "bugs": {
    "url": "https://github.com/japentaca/nexus-vue/issues"
  },
  "homepage": "https://github.com/japentaca/nexus-vue#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:smoke": "playwright test",
    "release:check": "npm run build && npm run test:smoke"
  },
  "peerDependencies": {
    "vue": "^3.5.34",
    "nexusui": "^2.1.6"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "vite": "^8.0.14"
  }
}